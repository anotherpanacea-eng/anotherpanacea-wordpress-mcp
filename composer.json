{
    "name": "anotherpanacea-eng/anotherpanacea-wordpress-mcp",
    "description": "MCP abilities for content management on anotherpanacea.com",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "wp-coding-standards/wpcs": "^3.0",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "lint": "find . -name '*.php' -not -path './vendor/*' -not -path './bundled/*' -print0 | xargs -0 php -l",
        "phpcs": "phpcs --standard=phpcs.xml",
        "test": "phpunit"
    }
}
